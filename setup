#!/bin/bash
#===============================================================================
# Universal Linux Setup Utility - Remote Controller
# Version: 1.0
# Author: Jackson Tong / Creekside Networks LLC
# License: MIT
#
# Description:
#   Universal setup and configuration utility for Linux servers.
#   Detects the remote OS and runs the appropriate sub-scripts via SSH.
#
# Supported OS:
#   - Rocky Linux 8, 9
#   - Ubuntu (planned)
#
# Usage:
#   setup [options] <[user@]host>
#   setup --local
#
#   Options:
#     --local             Configure this host directly (no SSH)
#     -p <port>           SSH port (default: 22)
#     -i <identity_file>  SSH private key file
#
#   Examples:
#     setup --local                             # configure this host directly
#     setup myhost                              # connects as root@myhost
#     setup admin@myhost                        # connects as admin@myhost
#     setup -p 2222 myhost                      # custom port
#     setup -i ~/.ssh/mykey -p 2222 myhost      # custom key and port
#===============================================================================

# Resolve symlinks to find real script directory
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Local UI helpers (colors, print_*, show_menu) — no bash4/root required
Red=$(tput setaf 1 2>/dev/null); Green=$(tput setaf 2 2>/dev/null)
Yellow=$(tput setaf 3 2>/dev/null); Blue=$(tput setaf 4 2>/dev/null)
Cyan=$(tput setaf 6 2>/dev/null); Bold=$(tput bold 2>/dev/null)
Reset=$(tput sgr0 2>/dev/null); Dim=$(tput dim 2>/dev/null)

print_ok()    { echo -e "  ${Green}✓${Reset} $1"; }
print_info()  { echo -e "  ${Blue}ℹ${Reset} $1"; }
print_error() { echo -e "  ${Red}✗${Reset} $1"; }
print_warn()  { echo -e "  ${Yellow}⚠${Reset} $1"; }

show_menu() {
    local title="$1"; shift
    local default_choice=0
    [[ "$1" =~ ^[0-9]+$ ]] && { default_choice=$1; shift; }
    local options=("$@")
    echo ""
    echo -e "${Green}${Bold}$title${Reset}"
    for i in "${!options[@]}"; do
        printf "  ${Cyan}%d)${Reset} %s\n" "$((i+1))" "${options[$i]}"
    done
    echo ""
    [[ $default_choice -gt 0 ]] && echo -n "  Select [$default_choice]: " || echo -n "  Select: "
    read user_choice
    [[ -z "$user_choice" ]] && user_choice=$default_choice
    if ! [[ "$user_choice" =~ ^[0-9]+$ ]] || (( user_choice < 1 || user_choice > ${#options[@]} )); then
        user_choice=$(( default_choice > 0 ? default_choice : ${#options[@]} ))
    fi
    menu_index=$(( user_choice - 1 ))
}

SSH_OPTS=()
TARGET=""
LOCAL_MODE=false

# Parse arguments: [--local] [-p port] [-i keyfile] [user@]host
while [[ $# -gt 0 ]]; do
    case "$1" in
        --local) LOCAL_MODE=true; shift ;;
        -p) SSH_OPTS+=(-p "$2"); shift 2 ;;
        -i) SSH_OPTS+=(-i "$2"); shift 2 ;;
        *)  TARGET="$1"; shift ;;
    esac
done

if [[ "$LOCAL_MODE" != "true" ]]; then
    if [[ -z "$TARGET" ]]; then
        TARGET="root@localhost"
    fi
    [[ "$TARGET" != *@* ]] && TARGET="root@$TARGET"
fi

# Default options added to every SSH call:
#   StrictHostKeyChecking=accept-new  — auto-accept unknown hosts; never silently fail on first connect
#   ConnectTimeout=10                 — fail fast instead of hanging
DEFAULT_SSH_OPTS=(-o StrictHostKeyChecking=accept-new -o ConnectTimeout=10)

# Verify SSH connectivity before attempting detection; give a clear error if it fails
check_ssh_connectivity() {
    local ssh_err
    ssh_err=$(ssh "${DEFAULT_SSH_OPTS[@]}" "${SSH_OPTS[@]}" "$TARGET" "exit 0" 2>&1)
    if [[ $? -ne 0 ]]; then
        print_error "Cannot connect to $TARGET"
        [[ -n "$ssh_err" ]] && echo -e "  ${Dim}$ssh_err${Reset}"
        print_info "Verify SSH access manually:  ssh ${SSH_OPTS[*]} $TARGET"
        exit 1
    fi
}

# Detect OS on the remote host — single round-trip for all three values
detect_remote_os() {
    local result
    result=$(ssh "${DEFAULT_SSH_OPTS[@]}" "${SSH_OPTS[@]}" "$TARGET" '
        ID=$(grep "^ID=" /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d "\"")
        VER=$(grep "^VERSION_ID=" /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d "\"" | cut -d. -f1)
        VIRT=$(systemd-detect-virt --container 2>/dev/null \
               || cat /run/systemd/container 2>/dev/null \
               || echo none)
        echo "$ID $VER $VIRT"
    ' 2>/dev/null)
    read -r REMOTE_OS REMOTE_OS_VERSION _virt <<< "$result"
    REMOTE_IS_LXC=false
    [[ "$_virt" == "lxc" || "$_virt" == "lxc-libvirt" ]] && REMOTE_IS_LXC=true
}

# Detect OS locally (--local mode)
detect_local_os() {
    REMOTE_OS=$(grep '^ID=' /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"')
    REMOTE_OS_VERSION=$(grep '^VERSION_ID=' /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"' | cut -d. -f1)
    local _virt
    _virt=$(systemd-detect-virt --container 2>/dev/null \
            || cat /run/systemd/container 2>/dev/null \
            || echo none)
    REMOTE_IS_LXC=false
    [[ "$_virt" == "lxc" || "$_virt" == "lxc-libvirt" ]] && REMOTE_IS_LXC=true
}

# Configure OS-specific script paths and menu-to-script mapping
configure_os() {
    case "$REMOTE_OS" in
        rocky)
            if [[ "$REMOTE_OS_VERSION" != "8" && "$REMOTE_OS_VERSION" != "9" ]]; then
                print_error "Rocky Linux $REMOTE_OS_VERSION is not supported (supported: 8, 9)"
                exit 1
            fi
            OS_LABEL="Rocky Linux $REMOTE_OS_VERSION"
            [[ "$REMOTE_IS_LXC" == "true" ]] && OS_LABEL+=" (LXC Container)"
            SCRIPTS_DIR="$SCRIPT_DIR/rockylinux"
            LIB_FILE="rl_lib.sh"
            MENU_SCRIPTS=(
                "rl_initialization.sh"
                "rl_update_mirrors.sh"
                "rl_install_desktop.sh"
                "rl_install_devtools.sh"
                "rl_install_remote_desktop.sh"
                "rl_update_network_settings.sh"
                "rl_enroll_domain.sh"
            )
            ;;
        ubuntu)
            print_error "Ubuntu support is not yet available"
            exit 1
            ;;
        *)
            print_error "Unsupported OS: '${REMOTE_OS:-unknown}'. Supported: Rocky Linux 8/9"
            exit 1
            ;;
    esac
}

# Run a sub-script — locally or via SSH depending on mode
run_remote() {
    local script_name="${MENU_SCRIPTS[$1]}"
    if [[ "$LOCAL_MODE" == "true" ]]; then
        bash <(cat "$SCRIPTS_DIR/$LIB_FILE" "$SCRIPTS_DIR/$script_name")
    else
        ssh -t "${DEFAULT_SSH_OPTS[@]}" "${SSH_OPTS[@]}" "$TARGET" "$(cat "$SCRIPTS_DIR/$LIB_FILE" "$SCRIPTS_DIR/$script_name")"
    fi
}

# Banner
echo ""
echo -e "${Cyan}╔═══════════════════════════════════════════════════════════╗${Reset}"
echo -e "${Cyan}║${Reset}  ${Bold}Linux Setup Utility${Reset}                                      ${Cyan}║${Reset}"
echo -e "${Cyan}║${Reset}  Version 1.0                                              ${Cyan}║${Reset}"
echo -e "${Cyan}║${Reset}  (c) 2021-2025 Creekside Networks LLC                     ${Cyan}║${Reset}"
echo -e "${Cyan}╚═══════════════════════════════════════════════════════════╝${Reset}"
echo ""

if [[ "$LOCAL_MODE" == "true" ]]; then
    echo -e "  Target: ${Green}${Bold}localhost (local)${Reset}"
    if [[ $EUID -ne 0 ]]; then
        print_error "Local mode requires root. Re-run with: sudo ./setup --local"
        exit 1
    fi
    print_info "Detecting local OS..."
    detect_local_os
else
    echo -e "  Target: ${Green}${Bold}$TARGET${Reset}"
    print_info "Connecting to $TARGET..."
    check_ssh_connectivity
    print_info "Detecting remote OS..."
    detect_remote_os
fi
configure_os
print_ok "Detected: $OS_LABEL"
[[ "$REMOTE_IS_LXC" == "true" ]] && print_warn "LXC container — firewalld, SELinux GRUB args, and disk expansion will be skipped"

# Main menu loop
while true; do
    menu_items=(
        "System Initialization"
        "Update Repository Mirrors"
        "Install Desktop Environment"
        "Install Development Tools"
        "Install Remote Desktop"
        "Configure Network"
        "Join Domain (AD/FreeIPA)"
        "Exit"
    )
    show_menu "Main Menu" 8 "${menu_items[@]}"
    case $menu_index in
        0) run_remote 0 ;;
        1) run_remote 1 ;;
        2) run_remote 2 ;;
        3) run_remote 3 ;;
        4) run_remote 4 ;;
        5) run_remote 5 ;;
        6) run_remote 6 ;;
        7) echo "Goodbye."; exit 0 ;;
    esac
done
